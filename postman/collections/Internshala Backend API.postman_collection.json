            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Sample Product\",\n  \"description\": \"A great product\",\n  \"price\": 29.99,\n  \"stockQuantity\": 100,\n  \"category\": \"Electronics\",\n  \"imageUrl\": \"https://example.com/image.jpg\"\n}",
