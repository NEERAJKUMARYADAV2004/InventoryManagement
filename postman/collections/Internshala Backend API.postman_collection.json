        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.collectionVariables.set(\"authToken\", jsonData.token);",
                  "}"
                ],
                "id": "416e7dc6-8924-455c-9278-96b7e934cffa"
              }
